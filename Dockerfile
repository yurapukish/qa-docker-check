# Базовий образ — офіційний Python 3.11 на мінімальному Debian (slim).
# Менший за звичайний на ~100MB, немає зайвих системних пакетів.
# Завжди вказуй конкретну версію — не latest, щоб білд був відтворюваним.
FROM python:3.11-slim

# Робоча директорія всередині контейнера.
# Всі наступні COPY, RUN, CMD виконуються відносно /app.
# Якщо папка не існує — Docker створить її автоматично.
WORKDIR /app

# Копіюємо ТІЛЬКИ requirements.txt — і нічого більше.
# Причина: Docker кешує кожен шар окремо.
# Якщо скопіювати весь код одразу і потім запустити pip install —
# будь-яка зміна в тест-файлі інвалідує кеш і pip перевстановить
# всі бібліотеки заново. Це коштує 30-60 секунд на кожному білді.
COPY requirements.txt .

# Встановлюємо залежності всередині контейнера під час збірки.
# --no-cache-dir — не зберігати pip-кеш у образі, зменшує розмір.
# Цей шар буде закешований доки requirements.txt не зміниться.
RUN pip install --no-cache-dir -r requirements.txt

# Тепер копіюємо весь проект.
# Робимо це ПІСЛЯ pip install — зміна коду не зачіпає шар з бібліотеками.
# Крапка зліва — все з поточної папки на хості.
# Крапка справа — в /app всередині контейнера (WORKDIR).
COPY . .

# CMD — команда яка виконується при docker run за замовчуванням.
# Можна перевизначити: docker run qa-api-tests pytest tests/ -k "smoke"
# -v               — verbose, показує назву кожного тесту
# --html           — генерує HTML-звіт у /app/reports/
# --self-contained-html — один файл без зовнішніх залежностей,
#                         зручно передавати як артефакт у CI
CMD ["pytest", "tests/", "-v", "--html=reports/report.html", "--self-contained-html"]